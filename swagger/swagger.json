    "/api/todos/{id}/complete": {
      "patch": {
        "tags": ["Todos"],
        "summary": "할일 완료/미완료 처리",
        "description": "특정 할일의 완료 상태를 변경합니다 (UC-08, BE-20).\n\n**비즈니스 규칙:**\n- BR-T-03: 자신이 소유한 할일만 처리 가능. 타인 소유 접근 시 403 반환 (리소스 존재 여부 노출 금지)\n- BR-T-04: is_completed=true 처리 시 completed_at에 현재 일시 자동 기록\n- BR-T-05: is_completed=false 처리 시 completed_at을 null로 초기화\n- BR-U-03: 인증된 사용자만 접근 가능",
        "operationId": "toggleTodoComplete",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "description": "완료/미완료 처리할 할일의 고유 식별자 (UUID)",
            "example": "c3d4e5f6-a7b8-9012-cdef-123456789012"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ToggleCompleteRequest"
              },
              "examples": {
                "complete": {
                  "summary": "완료 처리 (BR-T-04: completed_at 자동 기록)",
                  "value": {
                    "is_completed": true
                  }
                },
                "uncomplete": {
                  "summary": "미완료 복원 (BR-T-05: completed_at null 초기화)",
                  "value": {
                    "is_completed": false
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "완료/미완료 처리 성공",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Todo"
                },
                "examples": {
                  "completed": {
                    "summary": "완료 처리 성공 (BR-T-04)",
                    "value": {
                      "id": "c3d4e5f6-a7b8-9012-cdef-123456789012",
                      "user_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
                      "category_id": "00000000-0000-0000-0000-000000000002",
                      "title": "주간 보고서 작성",
                      "description": "이번 주 업무 진행 사항 정리",
                      "due_date": "2026-05-20",
                      "is_completed": true,
                      "completed_at": "2026-05-13T14:00:00.000Z",
                      "created_at": "2026-05-13T09:00:00.000Z",
                      "updated_at": "2026-05-13T14:00:00.000Z"
                    }
                  },
                  "uncompleted": {
                    "summary": "미완료 복원 성공 (BR-T-05)",
                    "value": {
                      "id": "c3d4e5f6-a7b8-9012-cdef-123456789012",
                      "user_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
                      "category_id": "00000000-0000-0000-0000-000000000002",
                      "title": "주간 보고서 작성",
                      "description": "이번 주 업무 진행 사항 정리",
                      "due_date": "2026-05-20",
                      "is_completed": false,
                      "completed_at": null,
