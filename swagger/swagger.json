                      "accessToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiJhMWIyYzNkNC1lNWY2LTc4OTAtYWJjZC1lZjEyMzQ1Njc4OTAiLCJpYXQiOjE3NDcxMzYwMDAsImV4cCI6MTc0NzIyMjQwMH0.signature"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "입력값 누락",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "missing_field": {
                    "summary": "필드 누락",
                    "value": {
                      "message": "이메일과 비밀번호를 입력해주세요.",
                      "code": "VALIDATION_ERROR"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "인증 실패 (이메일 또는 비밀번호 불일치). 보안상 계정 존재 여부를 구분하지 않음",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "invalid_credentials": {
