            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "missing_field": {
                    "summary": "is_completed 필드 누락",
                    "value": {
                      "message": "is_completed 값은 필수 입력값입니다.",
