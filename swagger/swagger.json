{
  "openapi": "3.0.3",
  "info": {
    "title": "TodoListApp API",
    "description": "인증된 사용자가 자신만의 할일을 카테고리별로 등록, 조회, 관리할 수 있는 개인 맞춤형 할일 관리 서비스 API입니다.\n\n## 인증 방식\n모든 보호된 엔드포인트는 `Authorization: Bearer <token>` 헤더가 필요합니다.\n로그인 후 발급된 JWT Access Token을 사용하세요.\n\n## 에러 응답 형식\n모든 에러 응답은 `{ \"message\": \"...\", \"code\": \"...\" }` 형식으로 반환됩니다.",
    "version": "1.0.0",
    "contact": {
      "name": "TodoListApp"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "개발 서버"
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "회원가입 및 로그인 (인증 불필요)"
    },
    {
      "name": "Users",
      "description": "사용자 정보 조회 및 수정 (인증 필요)"
    },
    {
      "name": "Categories",
      "description": "카테고리 목록 조회 및 생성 (인증 필요)"
    },
    {
      "name": "Todos",
      "description": "할일 CRUD 및 완료 처리 (인증 필요)"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "로그인 후 발급된 JWT Access Token을 입력하세요. 예: `Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...`"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "description": "사용자 정보 (password는 절대 응답에 포함하지 않음)",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "사용자 고유 식별자 (UUID)",
            "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "로그인 및 시스템 전체 식별에 사용하는 이메일. 가입 후 변경 불가 (BR-U-04)",
            "example": "user@example.com"
          },
          "name": {
            "type": "string",
            "description": "사용자 표시 이름. 수정 가능 (BR-U-04)",
            "example": "홍길동"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "회원 가입 일시 (ISO 8601)",
            "example": "2026-05-13T09:00:00.000Z"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "정보 마지막 수정 일시 (ISO 8601)",
            "example": "2026-05-13T10:30:00.000Z"
          }
        },
        "required": ["id", "email", "name", "created_at", "updated_at"]
      },
      "Category": {
        "type": "object",
        "description": "카테고리 정보. user_id가 null이면 시스템 기본 카테고리 (BR-C-01), 값이 있으면 사용자 정의 카테고리 (BR-C-02)",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "카테고리 고유 식별자 (UUID)",
            "example": "b2c3d4e5-f6a7-8901-bcde-f12345678901"
          },
          "user_id": {
            "type": "string",
            "format": "uuid",
            "nullable": true,
            "description": "소유 사용자 식별자. null이면 시스템 기본 카테고리 (BR-C-01). 값이 있으면 해당 사용자 전용 카테고리 (BR-C-02)",
            "example": null
          },
          "name": {
            "type": "string",
            "description": "카테고리 이름. 동일 사용자 내 중복 불가 (BR-C-04)",
            "example": "업무"
          },
          "is_default": {
            "type": "boolean",
            "description": "시스템 기본 카테고리 여부. true이면 수정/삭제 불가 (BR-C-01)",
            "example": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "카테고리 생성 일시 (ISO 8601)",
            "example": "2026-05-13T09:00:00.000Z"
          }
        },
        "required": ["id", "user_id", "name", "is_default", "created_at"]
      },
      "Todo": {
        "type": "object",
        "description": "할일 정보. 반드시 하나의 카테고리에 속해야 하며 (BR-T-01), 소유 사용자만 조회/수정/삭제 가능 (BR-T-03)",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "할일 고유 식별자 (UUID)",
            "example": "c3d4e5f6-a7b8-9012-cdef-123456789012"
          },
          "user_id": {
            "type": "string",
            "format": "uuid",
            "description": "소유 사용자 식별자 (BR-T-03)",
            "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
          },
          "category_id": {
            "type": "string",
            "format": "uuid",
            "description": "분류 카테고리 식별자. 필수값으로 반드시 존재하는 카테고리여야 함 (BR-T-01)",
            "example": "b2c3d4e5-f6a7-8901-bcde-f12345678901"
          },
          "title": {
            "type": "string",
            "maxLength": 500,
            "description": "할일 제목. 필수값 (BR-T-02), 최대 500자",
            "example": "주간 보고서 작성"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "description": "할일 상세 설명 (선택값)",
            "example": "이번 주 업무 진행 사항 정리 후 팀장님께 공유"
          },
          "due_date": {
            "type": "string",
            "format": "date",
            "nullable": true,
            "description": "종료예정일 (YYYY-MM-DD). 선택값이나, 입력 시 오늘 이후 날짜여야 함 (BR-T-06). 수정 시에도 동일 규칙 적용",
            "example": "2026-05-20"
          },
          "is_completed": {
            "type": "boolean",
            "description": "완료 여부. 기본값 false. 완료 처리 시 true, 미완료 복원 시 false (BR-T-04, BR-T-05)",
            "example": false
          },
          "completed_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "완료 처리 일시 (ISO 8601). 완료 처리 시 자동 기록 (BR-T-04), 미완료 복원 시 null 초기화 (BR-T-05)",
            "example": null
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "할일 등록 일시 (ISO 8601)",
            "example": "2026-05-13T09:00:00.000Z"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "할일 마지막 수정 일시 (ISO 8601)",
            "example": "2026-05-13T09:00:00.000Z"
          }
        },
        "required": [
          "id",
          "user_id",
          "category_id",
          "title",
          "description",
          "due_date",
          "is_completed",
          "completed_at",
          "created_at",
          "updated_at"
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "description": "공통 에러 응답 형식",
        "properties": {
          "message": {
            "type": "string",
            "description": "에러 메시지",
            "example": "요청 처리 중 오류가 발생했습니다."
          },
          "code": {
            "type": "string",
            "description": "에러 식별 코드 (선택값)",
            "example": "VALIDATION_ERROR"
          }
        },
        "required": ["message"]
      },
      "RegisterRequest": {
        "type": "object",
        "description": "회원가입 요청 본문",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "이메일 주소. 시스템 전체에서 고유해야 함 (BR-U-01)",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "minLength": 8,
            "description": "비밀번호. 최소 8자 이상. 서버에서 bcrypt로 해시 처리 후 저장 (BR-U-02)",
            "example": "securepassword123"
          },
          "name": {
            "type": "string",
            "description": "사용자 표시 이름. 필수값",
            "example": "홍길동"
          }
        },
        "required": ["email", "password", "name"]
      },
      "LoginRequest": {
        "type": "object",
        "description": "로그인 요청 본문",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "등록된 이메일 주소",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "description": "비밀번호",
            "example": "securepassword123"
          }
        },
        "required": ["email", "password"]
      },
      "LoginResponse": {
        "type": "object",
        "description": "로그인 성공 응답. JWT Access Token 반환",
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "JWT Access Token. 클라이언트는 Zustand authStore 메모리에만 저장해야 함 (localStorage/Cookie 금지)",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiJhMWIyYzNkNC1lNWY2LTc4OTAtYWJjZC1lZjEyMzQ1Njc4OTAiLCJpYXQiOjE3MDAwMDAwMDB9.abc123"
          }
        },
        "required": ["accessToken"]
      },
      "UpdateUserRequest": {
        "type": "object",
        "description": "사용자 정보 수정 요청. 이름 또는 비밀번호만 수정 가능. 이메일 변경 불가 (BR-U-04)",
        "properties": {
          "name": {
            "type": "string",
            "description": "변경할 표시 이름 (선택값)",
            "example": "김길동"
          },
          "current_password": {
            "type": "string",
            "description": "현재 비밀번호. 비밀번호 변경 시 필수 입력. 불일치 시 400 반환",
            "example": "currentpassword123"
          },
          "new_password": {
            "type": "string",
            "minLength": 8,
            "description": "새 비밀번호. 최소 8자 이상 (선택값). current_password와 함께 입력",
            "example": "newpassword456"
          }
        }
      },
      "CreateCategoryRequest": {
        "type": "object",
        "description": "카테고리 생성 요청",
        "properties": {
          "name": {
            "type": "string",
            "description": "카테고리 이름. 동일 사용자 내 중복 불가 (BR-C-04)",
            "example": "운동"
          }
        },
        "required": ["name"]
      },
      "CreateTodoRequest": {
        "type": "object",
        "description": "할일 생성 요청",
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 500,
            "description": "할일 제목. 필수값 (BR-T-02), 최대 500자",
            "example": "주간 보고서 작성"
          },
          "category_id": {
            "type": "string",
            "format": "uuid",
            "description": "카테고리 식별자. 필수값 (BR-T-01). 기본 카테고리 또는 본인 소유 사용자 정의 카테고리만 사용 가능 (BR-C-02)",
            "example": "b2c3d4e5-f6a7-8901-bcde-f12345678901"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "description": "할일 상세 설명 (선택값)",
            "example": "이번 주 업무 진행 사항 정리"
          },
          "due_date": {
            "type": "string",
            "format": "date",
            "nullable": true,
            "description": "종료예정일 (YYYY-MM-DD). 선택값이나, 입력 시 오늘 이후 날짜여야 함 (BR-T-06). 과거 날짜 입력 시 400 반환",
            "example": "2026-05-20"
          }
        },
        "required": ["title", "category_id"]
      },
      "UpdateTodoRequest": {
        "type": "object",
        "description": "할일 수정 요청. 변경할 필드만 포함 (PATCH 방식)",
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 500,
            "description": "변경할 할일 제목. 최대 500자 (선택값)",
            "example": "주간 보고서 작성 및 발표 준비"
          },
          "category_id": {
            "type": "string",
            "format": "uuid",
            "description": "변경할 카테고리 식별자 (선택값). 기본 카테고리 또는 본인 소유 사용자 정의 카테고리만 변경 가능 (BR-C-02)",
            "example": "b2c3d4e5-f6a7-8901-bcde-f12345678901"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "description": "변경할 상세 설명 (선택값). null 입력 시 설명 제거",
            "example": "보고서 작성 후 발표 자료도 준비"
          },
          "due_date": {
            "type": "string",
            "format": "date",
            "nullable": true,
            "description": "변경할 종료예정일 (YYYY-MM-DD, 선택값). 입력 시 오늘 이후 날짜여야 함 (BR-T-06). null 입력 시 종료예정일 제거",
            "example": "2026-05-22"
          }
        }
      },
      "ToggleCompleteRequest": {
        "type": "object",
        "description": "할일 완료/미완료 처리 요청",
        "properties": {
          "is_completed": {
            "type": "boolean",
            "description": "완료 여부. true이면 completed_at이 자동 기록 (BR-T-04), false이면 completed_at이 null로 초기화 (BR-T-05)",
            "example": true
          }
        },
        "required": ["is_completed"]
      },
      "MessageResponse": {
        "type": "object",
        "description": "단순 메시지 응답",
        "properties": {
          "message": {
            "type": "string",
            "description": "응답 메시지",
            "example": "처리가 완료되었습니다."
          }
        },
        "required": ["message"]
      }
    },
    "responses": {
      "UnauthorizedError": {
        "description": "인증 토큰이 없거나 만료됨 (BR-U-03)",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "examples": {
              "token_missing": {
                "summary": "토큰 없음",
                "value": {
                  "message": "인증 토큰이 필요합니다.",
                  "code": "TOKEN_MISSING"
                }
              },
              "token_expired": {
                "summary": "토큰 만료",
                "value": {
                  "message": "인증 토큰이 만료되었습니다. 다시 로그인해주세요.",
                  "code": "TOKEN_EXPIRED"
                }
              }
            }
          }
        }
      },
      "ForbiddenError": {
        "description": "접근 권한 없음. 타인 소유 리소스 접근 시 반환. 리소스 존재 여부는 노출하지 않음 (BR-T-03)",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "examples": {
              "forbidden": {
                "summary": "접근 권한 없음",
                "value": {
                  "message": "접근 권한이 없습니다.",
                  "code": "FORBIDDEN"
                }
              }
            }
          }
        }
      },
      "NotFoundError": {
        "description": "리소스를 찾을 수 없음 (단, 소유권 없을 때는 403으로 처리하여 존재 여부 노출 금지)",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "examples": {
              "not_found": {
                "summary": "리소스 없음",
                "value": {
                  "message": "요청한 리소스를 찾을 수 없습니다.",
                  "code": "NOT_FOUND"
                }
              }
            }
          }
        }
      },
      "ValidationError": {
        "description": "입력값 오류 또는 비즈니스 규칙 위반",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "examples": {
              "validation_error": {
                "summary": "입력값 오류",
                "value": {
                  "message": "입력값이 올바르지 않습니다.",
                  "code": "VALIDATION_ERROR"
                }
              }
            }
          }
        }
      }
    }
  },
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": ["Authentication"],
        "summary": "회원가입",
        "description": "새로운 사용자를 등록합니다 (UC-01).\n\n**비즈니스 규칙:**\n- BR-U-01: 이메일은 시스템 전체에서 고유해야 함. 중복 가입 불가\n- BR-U-02: 비밀번호는 bcrypt로 해시 처리 후 저장\n\n**입력 유효성:**\n- 이메일 형식 검증\n- 비밀번호 최소 8자\n- 이름 필수",
        "operationId": "register",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              },
              "examples": {
                "normal": {
                  "summary": "정상 요청",
                  "value": {
                    "email": "user@example.com",
                    "password": "securepassword123",
                    "name": "홍길동"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "회원가입 성공",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                },
                "examples": {
                  "success": {
                    "summary": "가입 성공",
                    "value": {
                      "message": "회원가입이 완료되었습니다."
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "입력값 오류 또는 이메일 중복",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "duplicate_email": {
                    "summary": "이메일 중복 (BR-U-01)",
                    "value": {
                      "message": "이미 사용 중인 이메일입니다.",
                      "code": "EMAIL_DUPLICATE"
                    }
                  },
                  "invalid_email": {
                    "summary": "이메일 형식 오류",
