    "/api/todos": {
      "get": {
        "tags": ["Todos"],
        "summary": "할일 목록 조회",
        "description": "현재 사용자의 할일 목록을 조회합니다. 쿼리 파라미터로 필터링이 가능합니다 (UC-06, BE-18).\n\n**비즈니스 규칙:**\n- BR-T-03: 자신이 소유한 할일만 조회 가능\n- BR-F-01: category_id 필터 — 선택한 카테고리에 속한 할일만 반환\n- BR-F-02: overdue 필터 — 현재 날짜 기준 due_date 초과 여부로 필터링\n- BR-F-03: is_completed 필터 — 완료/미완료 여부로 필터링\n- BR-F-04: 복수 필터 조건은 AND 조건으로 동시 적용\n- BR-U-03: 인증된 사용자만 접근 가능\n\n**정렬:** created_at 내림차순 (최신 순)",
        "operationId": "getTodos",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "category_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "description": "카테고리 필터. 선택한 카테고리에 속한 할일만 반환 (BR-F-01). 미입력 시 전체 카테고리 조회",
            "example": "b2c3d4e5-f6a7-8901-bcde-f12345678901"
          },
          {
            "name": "is_completed",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "description": "완료 여부 필터 (BR-F-03). true=완료된 할일만, false=미완료 할일만. 미입력 시 전체 조회",
            "example": false
          },
          {
            "name": "overdue",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "description": "기간 종료 여부 필터 (BR-F-02). true=오늘 날짜 기준 due_date 초과된 할일만, false=기간 내 할일만. 미입력 시 전체 조회",
            "example": true
          }
        ],
        "responses": {
